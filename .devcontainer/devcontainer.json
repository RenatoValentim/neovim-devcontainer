// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/
{
  "name": "devbox",
  "workspaceFolder": "/home/dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },

  "forwardPorts": [3000, 5173, 8000, 8080],

  "appPort": [3000, 5173, 8000],

  "remoteUser": "dev",

  "containerEnv": {
    "DISPLAY": "${localEnv:DISPLAY}",
    "SSH_AUTH_SOCK": "/ssh-agent"
  },

  "mounts": [
    "source=${localEnv:HOME}/Projects/me,target=/home/dev/projects,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.secrets,target=/home/dev/.secrets,type=bind,consistency=cached,readonly",
    "source=${localEnv:HOME}/.ssh,target=/home/dev/.ssh,type=bind,readonly",
    "source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent,type=bind",

    "source=/etc/localtime,target=/etc/localtime,type=bind,readonly",
    "source=/etc/timezone,target=/etc/timezone,type=bind,readonly",

    "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind",

    "source=/etc/ssl/certs,target=/etc/ssl/certs,type=bind,readonly",
    "source=/etc/ca-certificates,target=/etc/ca-certificates,type=bind,readonly"
  ],

  "postCreateCommand": "bash $HOME/projects/dotfiles/claude/setup-claude.sh"
}
